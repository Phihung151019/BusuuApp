<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="?kit_progress_bar_background_color" />
            <corners android:topLeftRadius="@dimen/dp_6" android:topRightRadius="@dimen/dp_6" android:bottomLeftRadius="@dimen/dp_6" android:bottomRightRadius="@dimen/dp_6" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <solid android:color="?kit_progress_bar_color" />
                <corners android:topLeftRadius="@dimen/dp_16" android:topRightRadius="@dimen/dp_16" android:bottomLeftRadius="@dimen/dp_16" android:bottomRightRadius="@dimen/dp_16" />
            </shape>
        </clip>
    </item>
</layer-list>
