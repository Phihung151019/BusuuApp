<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@color/rewind_button_disabled" />
                    <corners android:radius="@dimen/mission_start_button_radius" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@color/mission_start_button_pressed" />
                    <corners android:radius="@dimen/mission_start_button_radius" />
                </shape>
            </item>
            <item>
                <ripple android:color="@color/ripple_start_button">
                    <item android:id="@android:id/mask">
                        <shape>
                            <solid android:color="@color/mission_start_button_darker" />
                            <corners android:radius="@dimen/mission_start_button_radius" />
                        </shape>
                    </item>
                </ripple>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:bottom="@dimen/mission_start_shadow_height">
                <shape>
                    <solid android:color="@color/mission_start_button_dark" />
                    <corners android:radius="@dimen/mission_start_button_radius" />
                </shape>
            </item>
            <item android:top="@dimen/mission_start_shadow_height">
                <shape>
                    <solid android:color="@color/mission_start_button_darker" />
                    <corners android:radius="@dimen/mission_start_button_radius" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
