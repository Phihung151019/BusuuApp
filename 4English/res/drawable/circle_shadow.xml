<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <stroke android:width="1.0dp" android:color="#00000000" />
            <size android:height="@dimen/float_streak_btn_size" android:width="@dimen/float_streak_btn_size" />
        </shape>
    </item>
    <item android:left="1.0dp" android:top="1.0dp" android:right="1.0dp" android:bottom="1.0dp">
        <shape android:shape="oval">
            <stroke android:width="1.0dp" android:color="#05000000" />
            <size android:height="@dimen/float_streak_btn_size" android:width="@dimen/float_streak_btn_size" />
        </shape>
    </item>
    <item android:left="2.0dp" android:top="2.0dp" android:right="2.0dp" android:bottom="2.0dp">
        <shape android:shape="oval">
            <stroke android:width="1.0dp" android:color="#0a000000" />
            <size android:height="@dimen/float_streak_btn_size" android:width="@dimen/float_streak_btn_size" />
        </shape>
    </item>
    <item android:left="3.0dp" android:top="3.0dp" android:right="3.0dp" android:bottom="3.0dp">
        <shape android:shape="oval">
            <stroke android:width="1.0dp" android:color="#0f000000" />
            <size android:height="@dimen/float_streak_btn_size" android:width="@dimen/float_streak_btn_size" />
        </shape>
    </item>
    <item android:left="4.0dp" android:top="4.0dp" android:right="4.0dp" android:bottom="4.0dp">
        <shape android:shape="oval">
            <stroke android:width="1.0dp" android:color="#0f000000" />
            <solid android:color="@color/bg_white" />
            <size android:height="@dimen/float_streak_btn_size" android:width="@dimen/float_streak_btn_size" />
        </shape>
    </item>
</layer-list>
