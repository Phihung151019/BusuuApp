<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="ring" android:innerRadiusRatio="3.0" android:thicknessRatio="12.0" android:useLevel="false">
            <solid android:color="@color/home_progress_track" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <rotate android:fromDegrees="-90.0" android:toDegrees="0.0" android:pivotX="50.0%" android:pivotY="50.0%">
            <shape android:shape="ring" android:innerRadiusRatio="3.0" android:thicknessRatio="12.0" android:useLevel="true">
                <solid android:color="@color/home_progress_indicator" />
            </shape>
        </rotate>
    </item>
</layer-list>
