<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/chip_bg_selected" />
            <corners android:radius="100.0dp" />
            <stroke android:width="1.0dp" android:color="@color/chip_stroke_selected" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/chip_bg_normal" />
            <corners android:radius="100.0dp" />
            <stroke android:width="0.5dp" android:color="@color/chip_stroke_normal" />
        </shape>
    </item>
</selector>
