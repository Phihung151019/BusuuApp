<?xml version="1.0" encoding="utf-8"?>
<FrameLayout android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:gravity="center_horizontal" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:textSize="@dimen/textSizeMediumLarge" android:textColor="@color/text_title_dark" android:gravity="left" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="@dimen/generic_spacing_large" android:text="@string/help_others_filter_languages" />
                <androidx.recyclerview.widget.RecyclerView android:id="@id/language_selector_recycler_view" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" />
            </LinearLayout>
            <LinearLayout android:orientation="vertical" android:id="@id/conversation_types_layout" android:layout_width="match_parent" android:layout_height="wrap_content" android:divider="@drawable/divider_black_alpha_15" android:showDividers="middle">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/generic_spacing_32" android:layout_marginBottom="@dimen/generic_spacing_medium_large" android:text="@string/exercise_types" android:layout_marginStart="@dimen/generic_spacing_medium_large" style="@style/ListItemHeader" />
                <com.google.android.material.switchmaterial.SwitchMaterial android:textAppearance="@style/TextWeight.RobotoMedium" android:id="@id/writing_exercises_switch" android:padding="@dimen/generic_spacing_medium_large" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/show_writing_exercises" style="@style/LightGreenSwitchWithText" />
                <com.google.android.material.switchmaterial.SwitchMaterial android:textAppearance="@style/TextWeight.RobotoMedium" android:id="@id/spoken_exercises_switch" android:background="?selectableItemBackground" android:paddingTop="@dimen/generic_spacing_medium_large" android:paddingBottom="@dimen/generic_spacing_medium_large" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/show_speaking_exercises" android:paddingStart="@dimen/generic_spacing_medium_large" android:paddingEnd="@dimen/generic_spacing_medium_large" style="@style/LightGreenSwitchWithText" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
