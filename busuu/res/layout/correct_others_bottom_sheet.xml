<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout android:layout_width="match_parent" android:layout_height="@dimen/correction_top_banner" android:paddingHorizontal="@dimen/generic_16">
        <ImageView android:layout_gravity="start" android:id="@id/close_panel_icon" android:layout_width="wrap_content" android:layout_height="match_parent" android:src="@drawable/ic_close_black" app:tint="@color/busuu_grey_silver" />
        <TextView android:textSize="@dimen/textSize18" android:textStyle="bold" android:textColor="@color/text_grey_heading" android:layout_gravity="start|center" android:id="@id/close_panel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/add_a_correction" android:layout_marginStart="@dimen/generic_spacing_30" />
    </FrameLayout>
    <androidx.coordinatorlayout.widget.CoordinatorLayout android:layout_width="match_parent" android:layout_height="@dimen/match_constraint" android:layout_weight="1.0">
        <androidx.core.widget.NestedScrollView android:id="@id/bottom_sheet" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="@dimen/generic_16" app:behavior_hideable="false" app:behavior_peekHeight="@dimen/feedback_bottom_sheet_peek_height" app:layout_behavior="@string/bottom_sheet_behavior">
            <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
                <TextView android:textSize="@dimen/textSizeMedium" android:textColor="@color/text_grey_heading" android:id="@id/context_text" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/generic_8" android:layout_marginBottom="@dimen/generic_16" />
                <FrameLayout android:id="@id/text_correction_view" android:background="@drawable/correction_panel_background" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.busuu.android.social.correct.view.GreenCorrectionEditText android:textSize="@dimen/textSizeMediumLarge" android:textColor="@color/text_title_dark" android:id="@id/written_correction_view" android:background="@color/busuu_grey_xlite_background" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="@dimen/generic_spacing_large" android:inputType="textCapSentences|textMultiLine|textNoSuggestions" android:layout_marginHorizontal="@dimen/generic_16" />
                </FrameLayout>
                <include android:layout_gravity="center_horizontal" android:id="@id/recorder_view" android:layout_width="match_parent" android:layout_height="wrap_content" layout="@layout/view_compact_record_audio_controller" />
                <EditText android:textSize="@dimen/textSizeMediumLarge" android:textColor="@color/text_title_black" android:textColorHint="@color/text_hint" android:id="@id/correction_comment" android:background="@color/white_background" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/add_a_comment" android:layout_marginHorizontal="@dimen/generic_16" android:layout_marginVertical="@dimen/generic_24" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
    <FrameLayout android:layout_gravity="bottom" android:background="@color/white_background" android:layout_width="match_parent" android:layout_height="@dimen/correction_bottom_banner" android:elevation="@dimen/generic_elevation_xxbig">
        <ImageButton android:layout_gravity="end|center" android:id="@id/send_correction_button" android:background="@color/white_background" android:layout_width="wrap_content" android:layout_height="@dimen/generic_44" android:src="@drawable/ic_send_white_24dp" android:layout_marginEnd="@dimen/generic_12" app:tint="@color/blue" />
    </FrameLayout>
</LinearLayout>
