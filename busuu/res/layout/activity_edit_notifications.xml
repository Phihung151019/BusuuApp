<?xml version="1.0" encoding="utf-8"?>
<FrameLayout android:fitsSystemWindows="true" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:background="?colorSurfaceBackground" android:layout_width="match_parent" android:layout_height="match_parent">
        <include layout="@layout/include_toolbar" />
