                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@id/private_mode" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/private_mode" style="@style/LightGreenSwitchWithText" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/generic_spacing_small" android:text="@string/enabling_private_mode" style="@style/PreferencesSummary" />
                    </LinearLayout>
                    <View android:background="@drawable/divider_black_alpha_15" android:layout_width="match_parent" android:layout_height="1.0dp" android:layout_marginTop="@dimen/generic_spacing_medium_large" />
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/general" style="@style/PreferencesSectionTitle" />
                    <LinearLayout android:orientation="vertical" android:background="?selectableItemBackground" android:padding="@dimen/generic_spacing_medium_large" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/generic_spacing_large">
                        <com.google.android.material.switchmaterial.SwitchMaterial android:textAppearance="@style/TextWeight.RobotoMedium" android:id="@id/all_notifications" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/notifications" style="@style/LightGreenSwitchWithText" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/PreferencesRow">
                    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@id/correction_received" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/correction_received" style="@style/LightGreenSwitchWithText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/generic_spacing_small" android:text="@string/correction_received_example" style="@style/PreferencesSummary" />
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/PreferencesRow">
                    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@id/correction_added" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/correction_added" style="@style/LightGreenSwitchWithText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/generic_spacing_small" android:text="@string/correction_added_example" style="@style/PreferencesSummary" />
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/PreferencesRow">
                    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@id/replies" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/replies" style="@style/LightGreenSwitchWithText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/generic_spacing_small" android:text="@string/replies_example" style="@style/PreferencesSummary" />
