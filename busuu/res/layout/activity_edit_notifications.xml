                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/PreferencesRow">
                    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@id/friend_requests" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/friend_requests" style="@style/LightGreenSwitchWithText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/generic_spacing_small" android:text="@string/friend_requests_example" style="@style/PreferencesSummary" />
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/PreferencesRow">
                    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@id/correction_requests" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/correction_request" style="@style/LightGreenSwitchWithText" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/generic_spacing_small" android:text="@string/correction_request_example" style="@style/PreferencesSummary" />
